// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude": {
      "favorite_config_option_values": {
        "mode": [
          "plan"
        ]
      }
    },
    "github-copilot": {
      "favorite_models": ["gpt-5.2-codex", "claude-opus-4.5"],
      "type": "registry",
    },
  },
  "context_servers": {},
  "disable_ai": false,
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "sort_by_path": false,
  },
  "autosave": "on_focus_change",
  "project_panel": {
    "default_width": 360,
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": false,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": false
    },
    "notify_when_agent_waiting": "primary_screen",
    "message_editor_min_lines": 7,
    "use_modifier_to_send": true,
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4.5",
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5",
    },
    "play_sound_when_agent_done": false,
    "model_parameters": [],
    "dock": "right",
  },
  "terminal": {
    "dock": "bottom",
    "default_width": 640,
    "default_height": 420,
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "icon_theme": "VSCode Icons for Zed (Dark Official Icons)",
  "ui_font_size": 17,
  "buffer_font_size": 17,
  "buffer_font_weight": 500,
  "confirm_quit": false,
  "cursor_blink": true,
  "cursor_shape": "bar",
  "hide_mouse": "on_typing_and_movement",
  "format_on_save": "on",
  "formatter": "auto",
  "theme": "GitHub Dark High Contrast",
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "disabled_globs": [
      "**/.env*",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/.dev.vars",
      "**/secrets.yml",
    ],
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "neighbour",
    "show_close_button": "hover",
    "show_diagnostics": "off",
  },
  "languages": {
    "Markdown": {
      "format_on_save": "on",
    },
    "Python": {
      "language_servers": ["basedpyright", "ruff", "!pyright"],
      "format_on_save": "on",
      "formatter": [
        {
          "external": {
            "command": "ruff",
            "arguments": ["format", "-"],
          },
        },
        {
          "code_action": "source.fixAll.ruff",
        },
        {
          "code_action": "source.organizeImports.ruff",
        },
      ],
    },
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "basedpyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
        },
        "python": {
          "pythonPath": [".venv/bin/python", "venv/bin/python"],
        },
      },
    },
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true,
        },
      },
    },
  },
}
